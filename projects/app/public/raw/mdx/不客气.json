{
  "children":[
    {"children":[{"type":"text","value":"A polite response to expressions of thanks."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Usage Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"谢谢！不客气！"}],"type":"strong"},{"type":"text","value":" (xiè xie! bù kè qi!) - \"Thank you! You're welcome!\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不客气，应该的"}],"type":"strong"},{"type":"text","value":" (bù kè qi, yīng gāi de) - \"You're welcome, it's what I should do\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"真的不客气"}],"type":"strong"},{"type":"text","value":" (zhēn de bù kè qi) - \"really, don't mention it\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"跟我不用客气"}],"type":"strong"},{"type":"text","value":" (gēn wǒ bù yòng kè qi) - \"don't be polite with me\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Functions"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"不客气 serves important social functions:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Response to thanks"}],"type":"strong"},{"type":"text","value":": Standard reply to 谢谢 (thank you)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Encouraging informality"}],"type":"strong"},{"type":"text","value":": Making others feel comfortable"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Showing closeness"}],"type":"strong"},{"type":"text","value":": Indicating you don't need formal politeness"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Downplaying favor"}],"type":"strong"},{"type":"text","value":": Minimizing the significance of help given"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Politeness Spectrum"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"Chinese has different levels of \"you're welcome\":"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不客气"}],"type":"strong"},{"type":"text","value":" - casual, friendly \"you're welcome\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不用谢"}],"type":"strong"},{"type":"text","value":" - \"no need to thank\" (very casual)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"别客气"}],"type":"strong"},{"type":"text","value":" - \"don't be polite\" (encouraging familiarity)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"应该的"}],"type":"strong"},{"type":"text","value":" - \"it's what I should do\" (humble)"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"不客气 reflects Chinese relationship dynamics:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Breaking formality"}],"type":"strong"},{"type":"text","value":": Moving from stranger to friend relationship"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Mutual care"}],"type":"strong"},{"type":"text","value":": Showing people they don't need to be careful around you"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Harmonious interaction"}],"type":"strong"},{"type":"text","value":": Creating comfortable social atmosphere"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Reciprocal expectations"}],"type":"strong"},{"type":"text","value":": Understanding that help flows both ways"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"The phrase embodies the Chinese value of making others feel at ease."}],"type":"paragraph"}
