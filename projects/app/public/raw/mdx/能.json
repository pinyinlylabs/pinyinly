    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"能 represents "},{"children":[{"type":"text","value":"natural ability, physical capacity, or permission"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Physical ability"}],"type":"strong"},{"type":"text","value":": 我能跑很快 (wǒ néng pǎo hěn kuài) - \"I can run fast\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Permission"}],"type":"strong"},{"type":"text","value":": 你能来吗？ (nǐ néng lái ma?) - \"Can you come? / Are you able to come?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Possibility"}],"type":"strong"},{"type":"text","value":": 这能行吗？ (zhè néng xíng ma?) - \"Can this work? / Is this possible?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Capacity"}],"type":"strong"},{"type":"text","value":": 能容纳一百人 (néng róng nà yī bǎi rén) - \"can accommodate 100 people\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"能力"}],"type":"strong"},{"type":"text","value":" (nénglì) - \"ability; capability\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"能够"}],"type":"strong"},{"type":"text","value":" (nénggòu) - \"to be able to; to be capable of\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"可能"}],"type":"strong"},{"type":"text","value":" (kěnéng) - \"possible; maybe\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不能"}],"type":"strong"},{"type":"text","value":" (bù néng) - \"cannot; not able to\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"能源"}],"type":"strong"},{"type":"text","value":" (néngyuán) - \"energy; power source\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"才能"}],"type":"strong"},{"type":"text","value":" (cáinéng) - \"talent; ability\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"能 vs. 会 (néng vs. huì)"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"Understanding the important distinction:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"能"}],"type":"strong"},{"type":"text","value":" (néng): Natural ability, physical capacity, permission, possibility"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"会"}],"type":"strong"},{"type":"text","value":" (huì): Learned skill, acquired knowledge, \"know how to\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Examples:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"我能跑 (I am physically able to run) vs. 我会开车 (I know how to drive)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"你能来吗？(Are you able to come?) vs. 你会来吗？(Will you come?)"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Functions"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"能 serves multiple roles:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Modal verb"}],"type":"strong"},{"type":"text","value":": Expressing ability and possibility"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Auxiliary verb"}],"type":"strong"},{"type":"text","value":": Combined with main verbs to show capacity"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Permission indicator"}],"type":"strong"},{"type":"text","value":": Like English \"may\" or \"can\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Potential marker"}],"type":"strong"},{"type":"text","value":": Showing what's physically or practically possible"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"能 reflects Chinese thinking about:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Natural capacity"}],"type":"strong"},{"type":"text","value":": Recognition of inherent abilities and limitations"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Practical possibility"}],"type":"strong"},{"type":"text","value":": Focus on what can actually be accomplished"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Respect for capability"}],"type":"strong"},{"type":"text","value":": Acknowledging different levels of ability"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Efficiency"}],"type":"strong"},{"type":"text","value":": Understanding what's within one's power to do"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
