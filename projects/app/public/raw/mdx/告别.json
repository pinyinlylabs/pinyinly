    {"children":[{"type":"text","value":"告别 represents "},{"children":[{"type":"text","value":"the formal or emotional act of saying goodbye"}],"type":"strong"},{"type":"text","value":":"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Personal farewells"}],"type":"strong"},{"type":"text","value":": 告别朋友 (gào bié péng yǒu) - \"say goodbye to friends\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Permanent partings"}],"type":"strong"},{"type":"text","value":": 告别故乡 (gào bié gù xiāng) - \"bid farewell to hometown\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Life transitions"}],"type":"strong"},{"type":"text","value":": 告别童年 (gào bié tóng nián) - \"say goodbye to childhood\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Formal occasions"}],"type":"strong"},{"type":"text","value":": 告别仪式 (gào bié yí shì) - \"farewell ceremony\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
