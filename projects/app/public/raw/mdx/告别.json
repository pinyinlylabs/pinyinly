{
  "children":[
    {"children":[{"type":"text","value":"To say goodbye; to bid farewell; to take leave of someone."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Word Breakdown"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"告别 combines the concepts of announcing and separating."}],"type":"paragraph"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Component"}],"type":"tableCell"},{"children":[{"type":"text","value":"Meaning"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"告"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Tell; announce; inform; declare"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"别"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Separate; don't; another; part from"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"Together they create: \"announce the separation\" or \"declare the parting.\""}],"type":"paragraph"},
