{
  "children":[
    {"children":[{"type":"text","value":"An account or statement describing in detail an event, situation, or the like, usually as the result\nof observation or inquiry; report; to report."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"报告 represents "},{"children":[{"type":"text","value":"formal reporting, accounts, and official information delivery"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Formal presentations"}],"type":"strong"},{"type":"text","value":": 做报告 (zuò bàogào) - \"give a report\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Written documents"}],"type":"strong"},{"type":"text","value":": 研究报告 (yánjiū bàogào) - \"research report\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Verbal reporting"}],"type":"strong"},{"type":"text","value":": 报告情况 (bàogào qíngkuàng) - \"report the situation\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Official announcements"}],"type":"strong"},{"type":"text","value":": 政府报告 (zhèngfǔ bàogào) - \"government report\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"研究报告"}],"type":"strong"},{"type":"text","value":" (yánjiū bàogào) - \"research report\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"工作报告"}],"type":"strong"},{"type":"text","value":" (gōngzuò bàogào) - \"work report\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"做报告"}],"type":"strong"},{"type":"text","value":" (zuò bàogào) - \"give a report/presentation\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"报告会"}],"type":"strong"},{"type":"text","value":" (bàogào huì) - \"report meeting; briefing\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"调查报告"}],"type":"strong"},{"type":"text","value":" (diàochá bàogào) - \"investigation report\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"报告 is fundamental in Chinese academic, professional, and political contexts. In Chinese\neducational culture, students regularly give 报告 (presentations) to develop communication skills.\nIn government and business, formal 报告 carry significant weight and are expected to be\ncomprehensive and well-prepared. The concept emphasizes accountability and transparency in\ninformation sharing."}],"type":"paragraph"}
