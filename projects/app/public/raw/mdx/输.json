    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"输球"}],"type":"strong"},{"type":"text","value":" (shū qiú) - \"lose the ball game\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"输血"}],"type":"strong"},{"type":"text","value":" (shū xuè) - \"blood transfusion\" (blood flows from one to another)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不想输"}],"type":"strong"},{"type":"text","value":" (bù xiǎng shū) - \"don't want to lose\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"输得很惨"}],"type":"strong"},{"type":"text","value":" (shū de hěn cǎn) - \"lost badly; suffered a crushing defeat\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"输 is often paired with 赢 (yíng - to win) in Chinese culture. The concept of losing gracefully is\nvalued, and there's a saying \"输人不输阵\" - meaning even if you lose, don't lose your dignity or\nfighting spirit. In Chinese philosophy, losing can be seen as a learning opportunity."}],"type":"paragraph"}
