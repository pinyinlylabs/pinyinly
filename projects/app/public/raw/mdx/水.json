    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"River/Ocean"}],"type":"strong"},{"type":"text","value":": 江 (jiāng) \"river\", 海 (hǎi) \"ocean\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Weather"}],"type":"strong"},{"type":"text","value":": 雨 (yǔ) \"rain\", 雪 (xuě) \"snow\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Liquids"}],"type":"strong"},{"type":"text","value":": 酒 (jiǔ) \"alcohol\", 油 (yóu) \"oil\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Actions"}],"type":"strong"},{"type":"text","value":": 洗 (xǐ) \"wash\", 游 (yóu) \"swim\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"水 in Chinese culture:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"上善若水"}],"type":"strong"},{"type":"text","value":": \"The highest good is like water\" (Laozi - water nourishes without competing)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"One of the "},{"children":[{"type":"text","value":"五行"}],"type":"strong"},{"type":"text","value":" (five elements): 木火土金水 (wood, fire, earth, metal, water)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Associated with wisdom, flexibility, and persistence"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"风水"}],"type":"strong"},{"type":"text","value":" (fēng shuǐ) - \"wind and water\" (geomancy)"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
