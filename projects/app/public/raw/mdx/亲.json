    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Affectionate address"}],"type":"strong"},{"type":"text","value":": 亲爱的 (qīn'ài de) - \"dear; beloved\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Physical affection"}],"type":"strong"},{"type":"text","value":": 亲吻 (qīnwěn) - \"kiss\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Emotional closeness"}],"type":"strong"},{"type":"text","value":": 亲切 (qīnqiè) - \"kind; warm; cordial\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Personal involvement"}],"type":"strong"},{"type":"text","value":": 亲身 (qīnshēn) - \"personal; firsthand\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
