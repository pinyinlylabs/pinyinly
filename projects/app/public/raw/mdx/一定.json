    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"我一定去"}],"type":"strong"},{"type":"text","value":" (wǒ yī dìng qù) - \"I will definitely go\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"一定要小心"}],"type":"strong"},{"type":"text","value":" (yī dìng yào xiǎo xīn) - \"must be careful\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"他一定知道"}],"type":"strong"},{"type":"text","value":" (tā yī dìng zhī dào) - \"he certainly knows\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"一定不行"}],"type":"strong"},{"type":"text","value":" (yī dìng bù xíng) - \"definitely won't work\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"一定 functions as:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Adverb"}],"type":"strong"},{"type":"text","value":": Modifies verbs to show certainty (一定会来 - \"will definitely come\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Modal expression"}],"type":"strong"},{"type":"text","value":": Shows obligation or necessity (一定要 - \"must/have to\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Emphatic marker"}],"type":"strong"},{"type":"text","value":": Strengthens assertions and promises"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Future certainty"}],"type":"strong"},{"type":"text","value":": Often used with 会 (huì) for future events"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"In Chinese communication, 一定 carries strong commitment:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Promise weight"}],"type":"strong"},{"type":"text","value":": Using 一定 makes a statement more binding"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Social expectation"}],"type":"strong"},{"type":"text","value":": Creates accountability in relationships"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Confidence marker"}],"type":"strong"},{"type":"text","value":": Shows the speaker's strong belief or determination"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"}
