    {"children":[{"type":"text","value":"碰 represents "},{"children":[{"type":"text","value":"sudden contact, collision, and unexpected encounters"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Physical contact"}],"type":"strong"},{"type":"text","value":": 碰到 (pèng dào) - \"bump into; hit against\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Chance encounters"}],"type":"strong"},{"type":"text","value":": 碰见 (pèng jiàn) - \"run into; meet by chance\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Attempts"}],"type":"strong"},{"type":"text","value":": 碰运气 (pèng yùnqì) - \"try one's luck\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Problems"}],"type":"strong"},{"type":"text","value":": 碰上问题 (pèng shàng wèntí) - \"encounter problems\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
