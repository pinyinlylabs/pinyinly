  "children":[
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"月 represents "},{"children":[{"type":"text","value":"the moon, months, lunar cycles, and monthly periods"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"As \"moon\""}],"type":"strong"},{"type":"text","value":": 月亮 (yuèliàng) - \"moon\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"As \"month\""}],"type":"strong"},{"type":"text","value":": 一月 (yī yuè) - \"January\" (literally \"first month\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"For time periods"}],"type":"strong"},{"type":"text","value":": 上个月 (shàng gè yuè) - \"last month\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Lunar concepts"}],"type":"strong"},{"type":"text","value":": 月食 (yuèshí) - \"lunar eclipse\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
