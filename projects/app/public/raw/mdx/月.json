    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"三月"}],"type":"strong"},{"type":"text","value":" (sān yuè) - \"March\" (literally \"third month\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"月薪"}],"type":"strong"},{"type":"text","value":" (yuèxīn) - \"monthly salary\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"满月"}],"type":"strong"},{"type":"text","value":" (mǎnyuè) - \"full moon\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"月份"}],"type":"strong"},{"type":"text","value":" (yuèfèn) - \"month\" (time period)"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"As a Radical"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"月 is an important "},{"children":[{"type":"text","value":"radical"}],"type":"strong"},{"type":"text","value":" appearing in many characters related to:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Body parts"}],"type":"strong"},{"type":"text","value":": 肚 (dù) \"belly\", 肺 (fèi) \"lungs\" (actually the \"meat\" radical 肉)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Time"}],"type":"strong"},{"type":"text","value":": 期 (qī) \"period\", 朔 (shuò) \"new moon\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Light"}],"type":"strong"},{"type":"text","value":": 朦 (méng) \"dim moonlight\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"children":[{"type":"text","value":"Note"}],"type":"strong"},{"type":"text","value":": The body parts usage comes from 肉 (meat/flesh) which looks very similar to 月!"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Time"}],"type":"strong"},{"type":"text","value":": 期 (qī) \"period\", 朔 (shuò) \"new moon\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Light"}],"type":"strong"},{"type":"text","value":": 朦 (méng) \"dim moonlight\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"children":[{"children":[{"type":"text","value":"Note:"}],"type":"strong"},{"type":"text","value":" Many body part characters, such as 肚 (dù) \"belly\" and 肺 (fèi) \"lungs\", use a radical\nthat looks like 月 but is actually derived from the \"meat\" radical (肉). This radical is visually\nsimilar to 月, but its meaning and origin are different. Be careful not to confuse the two!"}],"type":"paragraph"}],"type":"blockquote"},
    {"children":[{"type":"text","value":"Cultural Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"月 in Chinese culture:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"日月"}],"type":"strong"},{"type":"text","value":": \"sun and moon\" (representing cosmic balance and time)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"月圆人团圆"}],"type":"strong"},{"type":"text","value":": \"when the moon is round, families reunite\" (Mid-Autumn Festival)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Associated with yin energy (gentle, receptive, feminine)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Central to traditional lunar calendar still used for festivals"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
