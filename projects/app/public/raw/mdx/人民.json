{
  "children":[
    {"children":[{"type":"text","value":"Citizens of a nation or region considered collectively."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Word Breakdown"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"人民 combines concepts of humanity and citizenship to represent the collective population."}],"type":"paragraph"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Component"}],"type":"tableCell"},{"children":[{"type":"text","value":"Meaning"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"人"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Person, human being - pictograph of standing figure"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"民"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"People, citizens - eye (目) + hidden/private (乚)"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"The combination emphasizes people as both individual humans and members of a collective community\nwith shared identity."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"人民 represents "},{"children":[{"type":"text","value":"the collective population of a nation or community, especially with political\nimplications"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"National identity"}],"type":"strong"},{"type":"text","value":": 中国人民 (Zhōngguó rénmín) - \"Chinese people\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Political context"}],"type":"strong"},{"type":"text","value":": 人民政府 (rénmín zhèngfǔ) - \"people's government\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Currency"}],"type":"strong"},{"type":"text","value":": 人民币 (rénmínbì) - \"people's currency (RMB)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Democratic ideals"}],"type":"strong"},{"type":"text","value":": 人民代表 (rénmín dàibiǎo) - \"people's representative\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"全国人民"}],"type":"strong"},{"type":"text","value":" (quánguó rénmín) - \"people of the whole country\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"人民群众"}],"type":"strong"},{"type":"text","value":" (rénmín qúnzhòng) - \"the masses; the people\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"为人民服务"}],"type":"strong"},{"type":"text","value":" (wèi rénmín fúwù) - \"serve the people\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"人民日报"}],"type":"strong"},{"type":"text","value":" (Rénmín Rìbào) - \"People's Daily (newspaper)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"人民大会堂"}],"type":"strong"},{"type":"text","value":" (Rénmín Dàhuìtáng) - \"Great Hall of the People\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"人民 carries profound political and cultural significance in modern Chinese society. It embodies\nideals of collective unity and shared responsibility that trace back to Confucian concepts of social\nharmony. In contemporary China, 人民 appears in many official contexts, reflecting the principle\nthat government serves the people's interests. The concept balances individual dignity with\ncollective identity, emphasizing that each person's wellbeing contributes to society's strength.\nThis reflects traditional Chinese values that see individual fulfillment and community prosperity as\ninterconnected rather than competing goals."}],"type":"paragraph"}
