    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"我有书"}],"type":"strong"},{"type":"text","value":" (wǒ yǒu shū) - \"I have a book\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"有人"}],"type":"strong"},{"type":"text","value":" (yǒu rén) - \"someone; there is someone\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"没有"}],"type":"strong"},{"type":"text","value":" (méi yǒu) - \"don't have; there isn't\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"有意思"}],"type":"strong"},{"type":"text","value":" (yǒu yì si) - \"interesting; meaningful\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"有 is one of the most important verbs in Chinese:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"Used to express possession: \"I have X\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Used to express existence: \"There is/are X\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Can indicate availability or presence"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Negated with 没 (méi) instead of 不 (bù): 没有 (méi yǒu)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Essential for describing what exists, what belongs to whom"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Foundation for countless everyday expressions and sentence patterns"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"有 reflects the Chinese understanding of possession and relationship between people and things,\nemphasizing the practical aspects of ownership and availability."}],"type":"paragraph"}
