{
  "children":[
    {"children":[{"type":"text","value":"The planet on which we live; Earth; the globe."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"地球 represents "},{"children":[{"type":"text","value":"our planet Earth as a celestial body"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"The planet"}],"type":"strong"},{"type":"text","value":": 保护地球 (bǎohù dìqiú) - \"protect the Earth\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Geography"}],"type":"strong"},{"type":"text","value":": 地球科学 (dìqiú kēxué) - \"Earth science\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Global context"}],"type":"strong"},{"type":"text","value":": 全地球 (quán dìqiú) - \"the entire Earth\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Environmental"}],"type":"strong"},{"type":"text","value":": 地球环境 (dìqiú huánjìng) - \"Earth's environment\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"地球村"}],"type":"strong"},{"type":"text","value":" (dìqiú cūn) - \"global village\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"地球日"}],"type":"strong"},{"type":"text","value":" (dìqiú rì) - \"Earth Day\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"地球仪"}],"type":"strong"},{"type":"text","value":" (dìqiú yí) - \"globe (the object)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"地球表面"}],"type":"strong"},{"type":"text","value":" (dìqiú biǎomiàn) - \"Earth's surface\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"地球科学"}],"type":"strong"},{"type":"text","value":" (dìqiú kēxué) - \"Earth science; geoscience\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"地球 represents both the scientific understanding of Earth as a planet and environmental\nconsciousness. In modern Chinese discourse, phrases like 保护地球 (protect the Earth)\nand 地球村 (global village) reflect growing awareness of environmental issues and global\ninterconnectedness. The concept emphasizes our shared planetary home."}],"type":"paragraph"}
