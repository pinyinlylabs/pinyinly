    {"children":[{"type":"text","value":"习 represents "},{"children":[{"type":"text","value":"the process of acquiring skills or knowledge through repetition and study"}],"type":"strong"},{"type":"text","value":". It's\nused:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Academic study"}],"type":"strong"},{"type":"text","value":": 学习 (xuéxí) - \"study; learn\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Skill practice"}],"type":"strong"},{"type":"text","value":": 练习 (liànxí) - \"practice; exercise\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Habit formation"}],"type":"strong"},{"type":"text","value":": 习惯 (xíguàn) - \"habit; custom\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Cultural learning"}],"type":"strong"},{"type":"text","value":": 风习 (fēngxí) - \"customs; practices\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
