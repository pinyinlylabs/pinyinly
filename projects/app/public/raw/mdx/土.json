    {"children":[{"type":"text","value":"As a Radical"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"土 is an important "},{"children":[{"type":"text","value":"radical"}],"type":"strong"},{"type":"text","value":" appearing in many earth-related characters:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Ground features"}],"type":"strong"},{"type":"text","value":": 地 (dì) \"earth/ground\", 场 (chǎng) \"field\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Construction"}],"type":"strong"},{"type":"text","value":": 城 (chéng) \"city\", 墙 (qiáng) \"wall\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Locations"}],"type":"strong"},{"type":"text","value":": 域 (yù) \"region\", 境 (jìng) \"boundary\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Soil types"}],"type":"strong"},{"type":"text","value":": 壤 (rǎng) \"fertile soil\", 坑 (kēng) \"pit\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Significance"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"土 holds deep meaning in Chinese culture:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Five Elements"}],"type":"strong"},{"type":"text","value":": One of 五行 (wǔ xíng) - 木火土金水 (wood, fire, earth, metal, water)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Central element"}],"type":"strong"},{"type":"text","value":": Earth is the center, balancing the other four elements"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Stability"}],"type":"strong"},{"type":"text","value":": 安土重迁 (ān tǔ zhòng qiān) - \"prefer staying on native soil\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Foundation"}],"type":"strong"},{"type":"text","value":": 落土为安 (luò tǔ wéi ān) - \"settling on earth brings peace\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
