    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"我们都来了"}],"type":"strong"},{"type":"text","value":" (wǒ men dōu lái le) - \"We all came\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"都是学生"}],"type":"strong"},{"type":"text","value":" (dōu shì xuéshēng) - \"All are students\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"都没有"}],"type":"strong"},{"type":"text","value":" (dōu méi yǒu) - \"All don't have\" / \"None have\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"都可以"}],"type":"strong"},{"type":"text","value":" (dōu kě yǐ) - \"All can\" / \"Everything is okay\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"都 is crucial for expressing totality and inclusion:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"Always comes before the verb it modifies"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Can refer to all members of a group previously mentioned"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Used with plural subjects to emphasize totality"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Essential for generalizations and universal statements"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Often used with 们 (men) to emphasize group inclusivity"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"都 reflects the Chinese cultural emphasis on group unity and collective identity, showing how\nindividual parts come together to form a unified whole."}],"type":"paragraph"}
