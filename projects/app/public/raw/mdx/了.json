    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"我吃了"}],"type":"strong"},{"type":"text","value":" (wǒ chī le) - \"I ate\" / \"I have eaten\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"下雨了"}],"type":"strong"},{"type":"text","value":" (xià yǔ le) - \"It's raining\" / \"It started to rain\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"他来了"}],"type":"strong"},{"type":"text","value":" (tā lái le) - \"He came\" / \"He has arrived\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"好了"}],"type":"strong"},{"type":"text","value":" (hǎo le) - \"Good!\" / \"Okay!\" / \"Done!\" / \"That's enough!\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"了 (le) is one of the most important particles in Chinese:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Completed action"}],"type":"strong"},{"type":"text","value":": Shows an action was finished in the past"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Change of state"}],"type":"strong"},{"type":"text","value":": Indicates a new situation has begun"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Immediate relevance"}],"type":"strong"},{"type":"text","value":": Often shows something just happened or is now true"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Can appear after verbs or at the end of sentences"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Essential for expressing past events and current situations"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Different from 了 (liǎo) which means \"to finish\" as a main verb"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"了 reflects the Chinese focus on situational awareness and the importance of knowing when things\nhave changed or been completed - essential for practical communication."}],"type":"paragraph"}
  ],
