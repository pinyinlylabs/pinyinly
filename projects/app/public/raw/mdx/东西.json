{
  "children":[
    {"children":[{"type":"text","value":"Thing; object; stuff; item; a general term for inanimate objects, possessions, or abstract concepts."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Word Breakdown"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"东西 literally means \"east-west\" but has evolved to mean \"thing\" - one of the most interesting\netymologies in Chinese."}],"type":"paragraph"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Component"}],"type":"tableCell"},{"children":[{"type":"text","value":"Literal Meaning"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"东"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"East - direction of the rising sun"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"西"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"West - direction of the setting sun"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"Understanding the Etymology"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"The evolution from \"east-west\" to \"thing\" reflects Chinese thinking:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Directional completeness"}],"type":"strong"},{"type":"text","value":": East to west covers everything spatially"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Temporal completeness"}],"type":"strong"},{"type":"text","value":": Dawn to dusk covers everything temporally"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Metaphorical extension"}],"type":"strong"},{"type":"text","value":": From \"all space\" to \"all objects in that space\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Linguistic elegance"}],"type":"strong"},{"type":"text","value":": A poetic way to say \"anything and everything\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Usage Examples"}],"depth":2,"type":"heading"},
    {"children":[{"children":[{"type":"text","value":"Physical Objects"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"这是什么东西？"}],"type":"strong"},{"type":"text","value":" (zhè shì shénme dōngxi?) - \"What is this thing?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"买东西"}],"type":"strong"},{"type":"text","value":" (mǎi dōngxi) - \"to buy things; to go shopping\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"好东西"}],"type":"strong"},{"type":"text","value":" (hǎo dōngxi) - \"good stuff; nice things\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"children":[{"type":"text","value":"Abstract Concepts"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"有意思的东西"}],"type":"strong"},{"type":"text","value":" (yǒuyìsi de dōngxi) - \"interesting things/stuff\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"没什么东西"}],"type":"strong"},{"type":"text","value":" (méi shénme dōngxi) - \"nothing much; nothing important\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"children":[{"type":"text","value":"Possessions"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"我的东西"}],"type":"strong"},{"type":"text","value":" (wǒ de dōngxi) - \"my things; my belongings\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"收拾东西"}],"type":"strong"},{"type":"text","value":" (shōushi dōngxi) - \"to pack up one's things\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"东西 is extremely versatile:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Countable"}],"type":"strong"},{"type":"text","value":": 一样东西 (yī yàng dōngxi) - \"one thing\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Uncountable"}],"type":"strong"},{"type":"text","value":": 很多东西 (hěn duō dōngxi) - \"a lot of stuff\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Question word"}],"type":"strong"},{"type":"text","value":": 什么东西 (shénme dōngxi) - \"what thing?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"With measure words"}],"type":"strong"},{"type":"text","value":": 几个东西 (jǐ gè dōngxi) - \"several things\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"东西 reflects Chinese linguistic creativity:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Metaphorical thinking"}],"type":"strong"},{"type":"text","value":": Using directions to represent objects"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Poetic language"}],"type":"strong"},{"type":"text","value":": Even everyday words have beautiful origins"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Completeness concept"}],"type":"strong"},{"type":"text","value":": The idea that east + west = everything"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Daily usage"}],"type":"strong"},{"type":"text","value":": One of the most common words in spoken Chinese"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"This word shows how Chinese thinking often uses "},{"children":[{"type":"text","value":"spatial and directional concepts"}],"type":"strong"},{"type":"text","value":" to express\nabstract ideas about objects and possessions."}],"type":"paragraph"}
