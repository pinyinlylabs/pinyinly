    {"children":[{"type":"text","value":"Usage Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"我会说中文"}],"type":"strong"},{"type":"text","value":" (wǒ huì shuō zhōng wén) - \"I can speak Chinese\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"他会开车"}],"type":"strong"},{"type":"text","value":" (tā huì kāi chē) - \"He can drive / knows how to drive\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"你会吗？"}],"type":"strong"},{"type":"text","value":" (nǐ huì ma?) - \"Can you do it? / Do you know how?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不会"}],"type":"strong"},{"type":"text","value":" (bù huì) - \"can't; don't know how to\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"会 indicates learned ability and acquired skills:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"Different from 能 (néng) which indicates general ability or permission"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Shows skills learned through practice and experience"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Often implies knowledge or competence gained over time"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Can indicate future possibility: \"will be able to\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Essential for discussing capabilities and talents"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"会 emphasizes the Chinese value of learning and skill development, showing that abilities come\nthrough education, practice, and cultural transmission rather than just natural talent."}],"type":"paragraph"}
  ],
  "type":"root"
}