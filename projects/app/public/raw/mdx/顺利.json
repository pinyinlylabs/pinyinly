    {"children":[{"type":"text","value":"顺利 represents "},{"children":[{"type":"text","value":"smooth progress without obstacles or difficulties"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Process description"}],"type":"strong"},{"type":"text","value":": 很顺利 (hěn shùnlì) - \"very smooth; going very well\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Wishes"}],"type":"strong"},{"type":"text","value":": 祝你顺利 (zhù nǐ shùnlì) - \"wish you success\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Completion"}],"type":"strong"},{"type":"text","value":": 顺利完成 (shùnlì wánchéng) - \"complete successfully\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Progress reports"}],"type":"strong"},{"type":"text","value":": 工作顺利 (gōngzuò shùnlì) - \"work is going smoothly\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
