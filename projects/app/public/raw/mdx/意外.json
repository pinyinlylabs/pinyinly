{
  "children":[
    {"children":[{"type":"text","value":"An event that happens by chance and was not expected; accident; unexpected; surprise."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"意外 represents "},{"children":[{"type":"text","value":"unexpected events, both positive and negative surprises"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Accidents"}],"type":"strong"},{"type":"text","value":": 交通意外 (jiāotōng yìwài) - \"traffic accident\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Surprises"}],"type":"strong"},{"type":"text","value":": 意外收获 (yìwài shōuhuò) - \"unexpected gain\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Unplanned events"}],"type":"strong"},{"type":"text","value":": 意外发生 (yìwài fāshēng) - \"happened unexpectedly\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"As adverb"}],"type":"strong"},{"type":"text","value":": 意外地 (yìwài de) - \"unexpectedly; by surprise\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"意外事故"}],"type":"strong"},{"type":"text","value":" (yìwài shìgù) - \"accident; unexpected incident\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"意外收获"}],"type":"strong"},{"type":"text","value":" (yìwài shōuhuò) - \"unexpected gain/harvest\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"交通意外"}],"type":"strong"},{"type":"text","value":" (jiāotōng yìwài) - \"traffic accident\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"意外惊喜"}],"type":"strong"},{"type":"text","value":" (yìwài jīngxǐ) - \"pleasant surprise\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"很意外"}],"type":"strong"},{"type":"text","value":" (hěn yìwài) - \"very surprising/unexpected\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"In Chinese culture, 意外 reflects the Buddhist and Taoist understanding that life is unpredictable\nand beyond complete human control. While 意外 can refer to negative accidents, it can also describe\npleasant surprises. The concept teaches acceptance that some things are \"outside intention\" and\nemphasizes the importance of adapting to unexpected circumstances."}],"type":"paragraph"}
