    {"children":[{"type":"text","value":"像 represents "},{"children":[{"type":"text","value":"resemblance, similarity, and comparison of appearance or characteristics"}],"type":"strong"},{"type":"text","value":". It's\nused:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Physical resemblance"}],"type":"strong"},{"type":"text","value":": 他像他父亲 (tā xiàng tā fùqīn) - \"He looks like his father\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Comparison"}],"type":"strong"},{"type":"text","value":": 像苹果一样 (xiàng píngguǒ yīyàng) - \"like an apple\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Seeming"}],"type":"strong"},{"type":"text","value":": 看像 (kàn xiàng) - \"seems like; appears to be\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Approximation"}],"type":"strong"},{"type":"text","value":": 像这样 (xiàng zhèyàng) - \"like this; in this manner\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
