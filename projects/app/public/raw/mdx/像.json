    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"看起来像"}],"type":"strong"},{"type":"text","value":" (kàn qǐlái xiàng) - \"looks like; appears to be\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"长得像"}],"type":"strong"},{"type":"text","value":" (zhǎng de xiàng) - \"looks like (in appearance)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"听起来像"}],"type":"strong"},{"type":"text","value":" (tīng qǐlái xiàng) - \"sounds like\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"像这样"}],"type":"strong"},{"type":"text","value":" (xiàng zhèyàng) - \"like this; in this way\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不像"}],"type":"strong"},{"type":"text","value":" (bù xiàng) - \"doesn't look like; unlike\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"In Chinese culture, 像 is frequently used to express family resemblance, which is considered\nimportant for family identity. Saying someone 像 their parents or grandparents is often a\ncompliment. The concept also extends to behavioral similarities - 像中国人 (like a Chinese person)\ncan refer to behaving according to Chinese cultural norms."}],"type":"paragraph"}
