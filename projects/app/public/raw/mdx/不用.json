    {"children":[{"type":"text","value":"不用 expresses "},{"children":[{"type":"text","value":"lack of necessity or obligation"}],"type":"strong"},{"type":"text","value":". It's used to:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Decline politely"}],"type":"strong"},{"type":"text","value":": 不用谢 (bù yòng xiè) - \"no need to thank/you're welcome\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Indicate no necessity"}],"type":"strong"},{"type":"text","value":": 不用担心 (bù yòng dānxīn) - \"no need to worry\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Give permission to skip"}],"type":"strong"},{"type":"text","value":": 不用去 (bù yòng qù) - \"don't need to go\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Express convenience"}],"type":"strong"},{"type":"text","value":": 不用麻烦 (bù yòng máfan) - \"no need to trouble yourself\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
