{
  "children":[
    {"children":[{"type":"text","value":"The floor below ground level; the lower part of a building; downstairs."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"楼下 represents "},{"children":[{"type":"text","value":"the lower floors or downstairs area of a building"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Location"}],"type":"strong"},{"type":"text","value":": 在楼下 (zài lóuxià) - \"downstairs; on the lower floor\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Direction"}],"type":"strong"},{"type":"text","value":": 到楼下去 (dào lóuxià qù) - \"go downstairs\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Reference point"}],"type":"strong"},{"type":"text","value":": 楼下的商店 (lóuxià de shāngdiàn) - \"the shop downstairs\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Living situation"}],"type":"strong"},{"type":"text","value":": 楼下邻居 (lóuxià línjū) - \"downstairs neighbor\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"在楼下"}],"type":"strong"},{"type":"text","value":" (zài lóuxià) - \"downstairs; on the lower floor\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"楼下邻居"}],"type":"strong"},{"type":"text","value":" (lóuxià línjū) - \"downstairs neighbor\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"到楼下"}],"type":"strong"},{"type":"text","value":" (dào lóuxià) - \"go downstairs\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"楼下大厅"}],"type":"strong"},{"type":"text","value":" (lóuxià dàtīng) - \"lobby downstairs\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"楼下等你"}],"type":"strong"},{"type":"text","value":" (lóuxià děng nǐ) - \"wait for you downstairs\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"In Chinese urban living, especially in apartment buildings, 楼下 is a common reference point for\nmeeting places, shops, and community spaces. Many apartment buildings have shops or\nservices 楼下 (downstairs), making it a practical and frequently used term in daily life. The\nconcept is essential for navigation in multi-story residential and commercial buildings."}],"type":"paragraph"}
