{
  "children":[
    {"children":[{"type":"text","value":"To deal with or manage a process or procedure; to handle; to process; to take care of."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"办理 represents "},{"children":[{"type":"text","value":"systematically handling processes, especially official or formal procedures"}],"type":"strong"},{"type":"text","value":".\nIt's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Official procedures"}],"type":"strong"},{"type":"text","value":": 办理手续 (bànlǐ shǒuxù) - \"handle procedures\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Applications"}],"type":"strong"},{"type":"text","value":": 办理护照 (bànlǐ hùzhào) - \"process a passport\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Business"}],"type":"strong"},{"type":"text","value":": 办理业务 (bànlǐ yèwù) - \"handle business\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Administrative"}],"type":"strong"},{"type":"text","value":": 办理登记 (bànlǐ dēngjì) - \"process registration\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"办理手续"}],"type":"strong"},{"type":"text","value":" (bànlǐ shǒuxù) - \"handle procedures; process paperwork\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"办理护照"}],"type":"strong"},{"type":"text","value":" (bànlǐ hùzhào) - \"apply for/process a passport\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"办理入学"}],"type":"strong"},{"type":"text","value":" (bànlǐ rùxué) - \"handle school enrollment\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"办理退款"}],"type":"strong"},{"type":"text","value":" (bànlǐ tuìkuǎn) - \"process a refund\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"办理业务"}],"type":"strong"},{"type":"text","value":" (bànlǐ yèwù) - \"conduct business; handle transactions\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"办理 is commonly used in bureaucratic and business contexts in Chinese society. It implies following\nproper procedures and protocols. In Chinese administrative culture, knowing how to 办理 various\nprocedures is considered an important life skill, as many official processes require careful\nattention to proper procedures and documentation."}],"type":"paragraph"}
