    {"children":[{"type":"text","value":"哪里 is the standard way to ask \"where\" in Mandarin:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"Often used with 在 (zài) \"at/in\" to ask about current location"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Can be used with 从 (cóng) \"from\" to ask about origin"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"More formal than 哪儿 (nǎr), which is more colloquial"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Essential question word for directions and location discussions"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"}
