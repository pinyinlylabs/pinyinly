    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"Ancient Chinese believed they were at the center of civilization"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Geographically central in their known world (surrounded by \"barbarian\" lands)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Culturally central - the source of civilization and proper governance"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"The emperor was the \"Son of Heaven\" ruling from the center of the earth"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"All other nations were considered peripheral to this central kingdom"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
