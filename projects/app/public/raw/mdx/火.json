    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Heat/Light"}],"type":"strong"},{"type":"text","value":": 热 (rè) \"hot\", 烈 (liè) \"intense\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Cooking"}],"type":"strong"},{"type":"text","value":": 烧 (shāo) \"burn/cook\", 烤 (kǎo) \"roast\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Energy"}],"type":"strong"},{"type":"text","value":": 爆 (bào) \"explode\", 燃 (rán) \"burn\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Illumination"}],"type":"strong"},{"type":"text","value":": 灯 (dēng) \"lamp\", 灿 (càn) \"brilliant\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
