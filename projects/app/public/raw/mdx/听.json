{
  "children":[
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"听 represents "},{"children":[{"type":"text","value":"active listening and auditory attention"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Basic listening"}],"type":"strong"},{"type":"text","value":": 听音乐 (tīng yīnyuè) - \"listen to music\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Hearing"}],"type":"strong"},{"type":"text","value":": 我听见了 (wǒ tīng jiàn le) - \"I heard it\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Following instructions"}],"type":"strong"},{"type":"text","value":": 听话 (tīng huà) - \"obey; be well-behaved\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Understanding"}],"type":"strong"},{"type":"text","value":": 听懂 (tīng dǒng) - \"understand (by listening)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"听到"}],"type":"strong"},{"type":"text","value":" (tīngdào) - \"hear; catch (a sound)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"听见"}],"type":"strong"},{"type":"text","value":" (tīngjiàn) - \"hear; detect auditorily\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"听说"}],"type":"strong"},{"type":"text","value":" (tīngshuō) - \"hear (a rumor); it is said that\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"好听"}],"type":"strong"},{"type":"text","value":" (hǎotīng) - \"pleasant to listen to; melodious\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"听力"}],"type":"strong"},{"type":"text","value":" (tīnglì) - \"hearing ability\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"听课"}],"type":"strong"},{"type":"text","value":" (tīng kè) - \"attend a lecture\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Extended Meanings"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"听 has important contextual uses:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Obedience"}],"type":"strong"},{"type":"text","value":": 听父母的话 (tīng fùmǔ de huà) - \"obey parents\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Following advice"}],"type":"strong"},{"type":"text","value":": 听医生的 (tīng yīshēng de) - \"follow the doctor's advice\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Rumor/hearsay"}],"type":"strong"},{"type":"text","value":": 听说... (tīngshuō...) - \"I heard that...\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Understanding"}],"type":"strong"},{"type":"text","value":": 听不懂 (tīng bù dǒng) - \"don't understand (what's being said)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Functions"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"听 serves multiple roles:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Transitive verb"}],"type":"strong"},{"type":"text","value":": 听 + object (listen to something)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Intransitive verb"}],"type":"strong"},{"type":"text","value":": 你听! (Listen!)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Complement"}],"type":"strong"},{"type":"text","value":": 听得清 (can hear clearly)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Command following"}],"type":"strong"},{"type":"text","value":": showing obedience or compliance"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Common Collocations"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"听不见"}],"type":"strong"},{"type":"text","value":" (tīng bù jiàn) - \"can't hear\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"听得到"}],"type":"strong"},{"type":"text","value":" (tīng de dào) - \"can hear; audible\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"听一听"}],"type":"strong"},{"type":"text","value":" (tīng yi tīng) - \"have a listen\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"听听"}],"type":"strong"},{"type":"text","value":" (tīngtīng) - \"listen (briefly)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"听 is central in Chinese culture for:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Respect and obedience"}],"type":"strong"},{"type":"text","value":": Listening shows proper respect to elders and authority"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Learning"}],"type":"strong"},{"type":"text","value":": Much knowledge transmission occurs through careful listening"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Social harmony"}],"type":"strong"},{"type":"text","value":": Good listening maintains relationships and understanding"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Moral character"}],"type":"strong"},{"type":"text","value":": The ability to listen well is considered a virtue"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"The character emphasizes that true listening involves not just hearing sounds, but paying\nrespectful, virtuous attention to what others are communicating."}],"type":"paragraph"}
