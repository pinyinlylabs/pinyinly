{
  "children":[
    {"children":[{"type":"text","value":"Describes someone or something that has good luck or fortune; lucky; fortunate."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"幸运 represents "},{"children":[{"type":"text","value":"being blessed with good luck or favorable circumstances"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Personal luck"}],"type":"strong"},{"type":"text","value":": 我很幸运 (wǒ hěn xìngyùn) - \"I'm very lucky\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Lucky events"}],"type":"strong"},{"type":"text","value":": 幸运的事 (xìngyùn de shì) - \"lucky thing\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Fortune description"}],"type":"strong"},{"type":"text","value":": 真幸运 (zhēn xìngyùn) - \"really lucky\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Lucky person"}],"type":"strong"},{"type":"text","value":": 幸运儿 (xìngyùn ér) - \"lucky person\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
