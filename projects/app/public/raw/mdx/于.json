    {"children":[{"type":"text","value":"于 is a "},{"children":[{"type":"text","value":"fundamental preposition"}],"type":"strong"},{"type":"text","value":" for indicating relationships. It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Location"}],"type":"strong"},{"type":"text","value":": 住于北京 (zhù yú Běijīng) - \"live in Beijing\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Time"}],"type":"strong"},{"type":"text","value":": 于今年 (yú jīnnián) - \"in this year\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Source"}],"type":"strong"},{"type":"text","value":": 来于中国 (lái yú Zhōngguó) - \"come from China\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Manner"}],"type":"strong"},{"type":"text","value":": 善于学习 (shàn yú xuéxí) - \"good at learning\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
