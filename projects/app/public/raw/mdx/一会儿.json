    {"children":[{"type":"text","value":"Grammar Patterns"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"一会儿 appears in several time expressions:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Position"}],"type":"strong"},{"type":"text","value":": Can go before or after the verb"}],"type":"paragraph"},{"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"我一会儿去 / 我去一会儿 - \"I'll go for a while\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"With 就"}],"type":"strong"},{"type":"text","value":": 一会儿就... - \"in just a moment...\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"With 过"}],"type":"strong"},{"type":"text","value":": 过一会儿 - \"after a while\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Repetition"}],"type":"strong"},{"type":"text","value":": 一会儿...一会儿 - \"sometimes...sometimes\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"一会儿 reflects Chinese concepts of time:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Flexible duration"}],"type":"strong"},{"type":"text","value":": Could mean minutes to an hour depending on context"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Politeness"}],"type":"strong"},{"type":"text","value":": Often used to soften requests (\"wait a moment please\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Casual tone"}],"type":"strong"},{"type":"text","value":": The 儿 suffix adds friendliness to conversations"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Relative time"}],"type":"strong"},{"type":"text","value":": Chinese time expressions are often contextual rather than precise"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"}
