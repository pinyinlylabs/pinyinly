    {"children":[{"type":"text","value":"云 represents "},{"children":[{"type":"text","value":"masses of water vapor suspended in the atmosphere"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Weather descriptions"}],"type":"strong"},{"type":"text","value":": 多云 (duōyún) - \"cloudy\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Sky observations"}],"type":"strong"},{"type":"text","value":": 白云 (báiyún) - \"white clouds\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Metaphorical uses"}],"type":"strong"},{"type":"text","value":": 云雾 (yúnwù) - \"clouds and mist; confusion\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Modern technology"}],"type":"strong"},{"type":"text","value":": 云计算 (yún jìsuàn) - \"cloud computing\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
