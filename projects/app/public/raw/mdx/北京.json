{
  "children":[
    {"children":[{"type":"text","value":"Beijing, the capital and political center of the People's Republic of China."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Word Breakdown"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"北京 literally means \"Northern Capital\" - reflecting its position as the northern political center\nof China."}],"type":"paragraph"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Component"}],"type":"tableCell"},{"children":[{"type":"text","value":"Meaning"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"北"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"North; northern direction"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"京"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Capital; metropolitan city"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"Understanding the Name"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"Think of 北京 as "},{"children":[{"type":"text","value":"\"the northern capital city\""}],"type":"strong"},{"type":"text","value":":"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"Historically distinguished from 南京 (Nanjing) - the \"Southern Capital\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Shows China's tradition of having multiple capital cities throughout history"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"The \"Northern Capital\" became the primary seat of imperial power"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Reflects geographic and political centralization in northern China"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"The name emphasizes its role as the administrative center"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Historical Significance"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"Beijing has served as China's capital for over 600 years:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Ming Dynasty"}],"type":"strong"},{"type":"text","value":": Established as the permanent capital in 1421"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Qing Dynasty"}],"type":"strong"},{"type":"text","value":": Continued as the imperial capital until 1912"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Modern Era"}],"type":"strong"},{"type":"text","value":": Became capital of the People's Republic of China in 1949"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Cultural Heritage"}],"type":"strong"},{"type":"text","value":": Home to the Forbidden City, Temple of Heaven, and other UNESCO World\nHeritage sites"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Modern Beijing"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"Today's Beijing (北京) includes:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Political Center"}],"type":"strong"},{"type":"text","value":": Seat of the Chinese government and Communist Party"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Cultural Hub"}],"type":"strong"},{"type":"text","value":": Center of Chinese arts, education, and media"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Economic Power"}],"type":"strong"},{"type":"text","value":": Major financial and business center"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Global City"}],"type":"strong"},{"type":"text","value":": Host of 2008 Olympics and 2022 Winter Olympics"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"The name 北京 represents not just a geographic location, but China's "},{"children":[{"type":"text","value":"political and cultural\nheart"}],"type":"strong"},{"type":"text","value":"."}],"type":"paragraph"}
