    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"平 (píng) – flat, level, even, peaceful"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"等 (děng) – rank, class, kind; equal; to wait"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"When combined, 平等 expresses the idea of equality or being equal, especially in terms of rights,\nstatus, or treatment."}],"type":"paragraph"},
    {"attributes":[],"children":[{"children":[{"type":"text","value":"Examples in sentences:"}],"type":"paragraph"},{"attributes":[],"children":[{"children":[{"attributes":[],"children":[{"type":"text","value":"我们主张人人平等。"}],"name":"Hanzi","type":"mdxJsxTextElement"},{"type":"text","value":"\n"},{"attributes":[],"children":[{"type":"text","value":"We advocate that everyone is equal."}],"name":"Translated","type":"mdxJsxTextElement"}],"type":"paragraph"}],"name":"Example","type":"mdxJsxFlowElement"},{"attributes":[],"children":[{"children":[{"attributes":[],"children":[{"type":"text","value":"性别平等非常重要。"}],"name":"Hanzi","type":"mdxJsxTextElement"},{"type":"text","value":"\n"},{"attributes":[],"children":[{"type":"text","value":"Gender equality is very important."}],"name":"Translated","type":"mdxJsxTextElement"}],"type":"paragraph"}],"name":"Example","type":"mdxJsxFlowElement"},{"attributes":[],"children":[{"children":[{"attributes":[],"children":[{"type":"text","value":"在法律面前，人人平等。"}],"name":"Hanzi","type":"mdxJsxTextElement"},{"type":"text","value":"\n"},{"attributes":[],"children":[{"type":"text","value":"Everyone is equal before the law."}],"name":"Translated","type":"mdxJsxTextElement"}],"type":"paragraph"}],"name":"Example","type":"mdxJsxFlowElement"}],"name":"Examples","type":"mdxJsxFlowElement"}
