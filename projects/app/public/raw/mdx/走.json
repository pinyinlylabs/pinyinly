    {"children":[{"type":"text","value":"走 represents "},{"children":[{"type":"text","value":"locomotion on foot and general movement"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Basic walking"}],"type":"strong"},{"type":"text","value":": 走路 (zǒu lù) - \"walk; go on foot\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Leaving"}],"type":"strong"},{"type":"text","value":": 我要走了 (wǒ yào zǒu le) - \"I have to go now\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Movement"}],"type":"strong"},{"type":"text","value":": 走过去 (zǒu guòqù) - \"walk over there\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Functioning"}],"type":"strong"},{"type":"text","value":": 表走得快 (biǎo zǒu de kuài) - \"the watch runs fast\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
