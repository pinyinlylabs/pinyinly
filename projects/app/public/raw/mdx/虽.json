    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"虽然...但是"}],"type":"strong"},{"type":"text","value":": 虽然很累，但是很开心 - \"although tired, but happy\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Concession structures"}],"type":"strong"},{"type":"text","value":": 虽说不容易 - \"although it's not easy\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Formal writing"}],"type":"strong"},{"type":"text","value":": 虽有困难 - \"although there are difficulties\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Always followed by contrast"}],"type":"strong"},{"type":"text","value":": Never stands alone in modern Chinese"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
