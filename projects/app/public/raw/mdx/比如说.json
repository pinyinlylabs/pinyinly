    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Introducing examples"}],"type":"strong"},{"type":"text","value":": \"比如说，北京\" - \"for example, Beijing\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Clarification"}],"type":"strong"},{"type":"text","value":": \"比如说这个问题\" - \"take this problem for instance\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Illustration"}],"type":"strong"},{"type":"text","value":": \"比如说昨天的事\" - \"like what happened yesterday\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Explanation"}],"type":"strong"},{"type":"text","value":": \"比如说他的工作\" - \"for instance, his work\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
