    {"children":[{"type":"text","value":"Directional Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"去 is frequently used as a directional complement indicating movement away from the speaker:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"走去"}],"type":"strong"},{"type":"text","value":" (zǒu qù) - \"walk away (from speaker)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"跑去"}],"type":"strong"},{"type":"text","value":" (pǎo qù) - \"run away (from speaker)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"飞去"}],"type":"strong"},{"type":"text","value":" (fēi qù) - \"fly away (from speaker)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Functions"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"去 serves multiple grammatical roles:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Motion verb"}],"type":"strong"},{"type":"text","value":": Basic verb meaning \"to go\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Directional complement"}],"type":"strong"},{"type":"text","value":": Added to verbs to show departure"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Destination indicator"}],"type":"strong"},{"type":"text","value":": 去... \"go to...\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Purpose indicator"}],"type":"strong"},{"type":"text","value":": 去做... \"go to do...\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Come vs. Go (来 vs. 去)"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"Understanding the contrast:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"来"}],"type":"strong"},{"type":"text","value":" (lái): Movement toward the speaker - \"come\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"去"}],"type":"strong"},{"type":"text","value":" (qù): Movement away from the speaker - \"go\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Perspective matters: 我来你家 (I come to your house) vs. 我去商店 (I go to the store)"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
