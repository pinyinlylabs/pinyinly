    {"children":[{"type":"text","value":"去 represents "},{"children":[{"type":"text","value":"movement away from the speaker or departure"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Basic departure"}],"type":"strong"},{"type":"text","value":": 我去学校 (wǒ qù xuéxiào) - \"I go to school\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Leaving"}],"type":"strong"},{"type":"text","value":": 他去了 (tā qù le) - \"He left / He has gone\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Destination"}],"type":"strong"},{"type":"text","value":": 去北京 (qù Běijīng) - \"go to Beijing\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Future action"}],"type":"strong"},{"type":"text","value":": 明天去 (míngtiān qù) - \"go tomorrow\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
