    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"他住在上海 (tā zhù zài shànghǎi) - \"He lives in Shanghai\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"我们住在学校附近 (wǒmen zhù zài xuéxiào fùjìn) - \"We live near the school\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
