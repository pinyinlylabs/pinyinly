    {"children":[{"type":"text","value":"与 indicates "},{"children":[{"type":"text","value":"association, partnership, or conjunction between entities"}],"type":"strong"},{"type":"text","value":". It's used for:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Formal conjunction"}],"type":"strong"},{"type":"text","value":": 父亲与母亲 (fùqīn yǔ mǔqīn) - \"father and mother\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Partnership"}],"type":"strong"},{"type":"text","value":": 与人合作 (yǔ rén hézuò) - \"cooperate with people\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Comparison"}],"type":"strong"},{"type":"text","value":": 与...相比 (yǔ...xiāngbǐ) - \"compared with...\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Accompaniment"}],"type":"strong"},{"type":"text","value":": 与朋友一起 (yǔ péngyǒu yīqǐ) - \"together with friends\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
