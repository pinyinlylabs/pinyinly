    {"children":[{"type":"text","value":"亡 represents "},{"children":[{"type":"text","value":"departure of life or loss of something vital"}],"type":"strong"},{"type":"text","value":". It's used for:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Death"}],"type":"strong"},{"type":"text","value":": 死亡 (sǐwáng) - \"death/to die\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Loss"}],"type":"strong"},{"type":"text","value":": 亡失 (wángshī) - \"to lose/be lost\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Escape"}],"type":"strong"},{"type":"text","value":": 逃亡 (táowáng) - \"to flee/escape\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Extinction"}],"type":"strong"},{"type":"text","value":": 灭亡 (mièwáng) - \"to perish/become extinct\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
