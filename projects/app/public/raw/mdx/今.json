    {"children":[{"type":"text","value":"今 represents "},{"children":[{"type":"text","value":"the current time period, whether momentary or extending to today"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Present moment"}],"type":"strong"},{"type":"text","value":": 现在 (xiànzài) often pairs with 今"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Today"}],"type":"strong"},{"type":"text","value":": 今天 (jīntiān) - \"today\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Current period"}],"type":"strong"},{"type":"text","value":": 今年 (jīnnián) - \"this year\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Immediate time"}],"type":"strong"},{"type":"text","value":": 今后 (jīnhòu) - \"from now on\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
