{
  "children":[
    {"children":[{"type":"text","value":"In a proper or satisfactory way; properly; well; carefully; thoroughly."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"好好 represents "},{"children":[{"type":"text","value":"doing things with proper care, attention, and thoroughness"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Instructions"}],"type":"strong"},{"type":"text","value":": 好好学习 (hǎohǎo xuéxí) - \"study properly\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Advice"}],"type":"strong"},{"type":"text","value":": 好好休息 (hǎohǎo xiūxi) - \"rest well\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Emphasis"}],"type":"strong"},{"type":"text","value":": 好好想想 (hǎohǎo xiǎngxiang) - \"think carefully\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Encouragement"}],"type":"strong"},{"type":"text","value":": 好好工作 (hǎohǎo gōngzuò) - \"work hard/well\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"好好学习"}],"type":"strong"},{"type":"text","value":" (hǎohǎo xuéxí) - \"study hard; study properly\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"好好休息"}],"type":"strong"},{"type":"text","value":" (hǎohǎo xiūxi) - \"rest well; get proper rest\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"好好想想"}],"type":"strong"},{"type":"text","value":" (hǎohǎo xiǎngxiang) - \"think it over carefully\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"好好工作"}],"type":"strong"},{"type":"text","value":" (hǎohǎo gōngzuò) - \"work hard; do good work\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"好好说话"}],"type":"strong"},{"type":"text","value":" (hǎohǎo shuōhuà) - \"speak properly; be civil\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"好好 reflects Chinese cultural values of diligence, thoroughness, and proper behavior. It's commonly\nused by parents, teachers, and authority figures to encourage proper effort and attention. The\nrepetition emphasizes the importance of not just doing something, but doing it with the right\nattitude and complete commitment, reflecting Confucian values of self-cultivation and excellence."}],"type":"paragraph"}
