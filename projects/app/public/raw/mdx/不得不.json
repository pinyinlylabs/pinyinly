    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Reluctant obligation"}],"type":"strong"},{"type":"text","value":": 不得不工作 (bù dé bù gōngzuò) - \"have to work\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Forced circumstances"}],"type":"strong"},{"type":"text","value":": 不得不离开 (bù dé bù líkāi) - \"have no choice but to leave\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Unwilling admission"}],"type":"strong"},{"type":"text","value":": 不得不承认 (bù dé bù chéngrèn) - \"have to admit\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Compelled action"}],"type":"strong"},{"type":"text","value":": 不得不说 (bù dé bù shuō) - \"must say; have to say\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
