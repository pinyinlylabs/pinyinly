    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"书 represents "},{"children":[{"type":"text","value":"physical or digital written works containing information, stories, or knowledge"}],"type":"strong"},{"type":"text","value":".\nIt's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Physical books"}],"type":"strong"},{"type":"text","value":": 看书 (kàn shū) - \"read books\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Academic texts"}],"type":"strong"},{"type":"text","value":": 教科书 (jiàokēshū) - \"textbook\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Literature"}],"type":"strong"},{"type":"text","value":": 小说书 (xiǎoshuō shū) - \"novel\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Reference works"}],"type":"strong"},{"type":"text","value":": 字典书 (zìdiǎn shū) - \"dictionary book\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
