{
  "children":[
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"是 is the fundamental "},{"children":[{"type":"text","value":"copula verb"}],"type":"strong"},{"type":"text","value":" (linking verb) in Chinese, essential for:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Identity"}],"type":"strong"},{"type":"text","value":": 我是学生 (wǒ shì xuéshēng) - \"I am a student\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Affirmation"}],"type":"strong"},{"type":"text","value":": 是的 (shì de) - \"yes; that's right\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Emphasis"}],"type":"strong"},{"type":"text","value":": 是我做的 (shì wǒ zuò de) - \"it was I who did it\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Equivalence"}],"type":"strong"},{"type":"text","value":": 一加一是二 (yī jiā yī shì èr) - \"one plus one is two\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"这是我的书"}],"type":"strong"},{"type":"text","value":" (zhè shì wǒ de shū) - \"This is my book\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"他是中国人"}],"type":"strong"},{"type":"text","value":" (tā shì Zhōngguó rén) - \"He is Chinese\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"今天是星期一"}],"type":"strong"},{"type":"text","value":" (jīntiān shì xīngqīyī) - \"Today is Monday\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"是不是？"}],"type":"strong"},{"type":"text","value":" (shì bù shì?) - \"Is it or isn't it? / Right?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"是 is absolutely fundamental in Chinese:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Links subjects to predicates"}],"type":"strong"},{"type":"text","value":" (like \"is/am/are\" in English)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Can be negated"}],"type":"strong"},{"type":"text","value":": 不是 (bù shì) - \"is not\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Forms questions"}],"type":"strong"},{"type":"text","value":": 是吗？(shì ma?) - \"Really? / Is that so?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Shows emphasis"}],"type":"strong"},{"type":"text","value":" when used before verbs or phrases"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Essential for all identification and description"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"是 represents the Chinese philosophical emphasis on truth, correctness, and clarity. In traditional\nChinese thinking, truth should be as obvious and undeniable as the sun - there's no ambiguity when\nsomething truly IS. This reflects cultural values of directness, honesty, and the importance of\naccurate identification in social relationships and formal contexts."}],"type":"paragraph"}
