{
  "children":[
    {"children":[{"type":"text","value":"A person who is invited to visit or stay in someone's home; guest; visitor; customer."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"客人 represents "},{"children":[{"type":"text","value":"people who visit, stay, or are served in various contexts"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Home visitors"}],"type":"strong"},{"type":"text","value":": 家里有客人 (jiālǐ yǒu kèrén) - \"there are guests at home\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Hotel context"}],"type":"strong"},{"type":"text","value":": 酒店客人 (jiǔdiàn kèrén) - \"hotel guests\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Business"}],"type":"strong"},{"type":"text","value":": 重要客人 (zhòngyào kèrén) - \"important customers\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Formal occasions"}],"type":"strong"},{"type":"text","value":": 尊贵客人 (zūnguì kèrén) - \"honored guests\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"重要客人"}],"type":"strong"},{"type":"text","value":" (zhòngyào kèrén) - \"important guest/customer\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"请客人"}],"type":"strong"},{"type":"text","value":" (qǐng kèrén) - \"invite guests\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"客人来了"}],"type":"strong"},{"type":"text","value":" (kèrén lái le) - \"the guests have arrived\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"贵客人"}],"type":"strong"},{"type":"text","value":" (guì kèrén) - \"honored/distinguished guest\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"招待客人"}],"type":"strong"},{"type":"text","value":" (zhāodài kèrén) - \"receive/entertain guests\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"In Chinese culture, 客人 (guests) hold a special position and are treated with great respect and\nhospitality. The concept of 客气 (politeness) literally means \"guest energy,\" reflecting how hosts\nshould treat others with the same courtesy shown to guests. Proper treatment of 客人 is considered a\nreflection of one's character and family upbringing."}],"type":"paragraph"}
