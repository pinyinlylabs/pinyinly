    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"有害"}],"type":"strong"},{"type":"text","value":" (yǒuhài) - \"harmful; detrimental\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"害怕"}],"type":"strong"},{"type":"text","value":" (hàipà) - \"fear; be afraid\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"害虫"}],"type":"strong"},{"type":"text","value":" (hàichóng) - \"pest; harmful insect\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"伤害"}],"type":"strong"},{"type":"text","value":" (shānghài) - \"injure; wound; harm\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"害处"}],"type":"strong"},{"type":"text","value":" (hàichu) - \"harm; disadvantage\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"害 in Chinese culture represents not just physical harm but also moral and social damage. The\nconcept includes harm to relationships, reputation, and community harmony. Traditional Chinese\nmedicine and philosophy emphasize preventing 害 through balance and proper care, reflecting a\nholistic view of harm that extends beyond just physical injury to include emotional and spiritual\nwell-being."}],"type":"paragraph"}
