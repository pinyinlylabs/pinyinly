{
  "children":[
    {"children":[{"type":"text","value":"The land or area adjacent to a road; roadside; beside the road."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"路边 represents "},{"children":[{"type":"text","value":"the area immediately adjacent to roads and pathways"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Location"}],"type":"strong"},{"type":"text","value":": 在路边 (zài lùbiān) - \"by the roadside\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Parking"}],"type":"strong"},{"type":"text","value":": 路边停车 (lùbiān tíngchē) - \"roadside parking\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Shops"}],"type":"strong"},{"type":"text","value":": 路边摊 (lùbiān tān) - \"roadside stall\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Activities"}],"type":"strong"},{"type":"text","value":": 路边等车 (lùbiān děng chē) - \"wait for a bus by the roadside\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"路边摊"}],"type":"strong"},{"type":"text","value":" (lùbiān tān) - \"roadside stall/vendor\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"路边停车"}],"type":"strong"},{"type":"text","value":" (lùbiān tíngchē) - \"roadside parking\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"在路边"}],"type":"strong"},{"type":"text","value":" (zài lùbiān) - \"by the roadside; at the roadside\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"路边咖啡店"}],"type":"strong"},{"type":"text","value":" (lùbiān kāfēi diàn) - \"roadside café\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"路边等"}],"type":"strong"},{"type":"text","value":" (lùbiān děng) - \"wait by the roadside\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"路边 is significant in Chinese urban culture, especially for 路边摊 (roadside food stalls) which are\nan integral part of street food culture. Many small businesses operate 路边, providing convenient\nservices to pedestrians and drivers. The concept represents the informal, accessible economy that\nthrives in the spaces adjacent to major thoroughfares."}],"type":"paragraph"}
