  "children":[
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"交 represents "},{"children":[{"type":"text","value":"the action of crossing, meeting, or exchanging between entities"}],"type":"strong"},{"type":"text","value":". It's used for:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Handing over"}],"type":"strong"},{"type":"text","value":": 交给 (jiāo gěi) - \"hand over to/give to\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Making friends"}],"type":"strong"},{"type":"text","value":": 交朋友 (jiāo péngyǒu) - \"make friends\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Intersecting"}],"type":"strong"},{"type":"text","value":": 交叉 (jiāochā) - \"intersect/cross\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Communication"}],"type":"strong"},{"type":"text","value":": 交流 (jiāoliú) - \"exchange/communicate\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"交通"}],"type":"strong"},{"type":"text","value":" (jiāotōng) - \"traffic/transportation\" (crossing and flowing)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"交易"}],"type":"strong"},{"type":"text","value":" (jiāoyì) - \"transaction/trade\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"交换"}],"type":"strong"},{"type":"text","value":" (jiāohuàn) - \"exchange/swap\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"外交"}],"type":"strong"},{"type":"text","value":" (wàijiāo) - \"diplomacy\" (outside + hand over)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"交往"}],"type":"strong"},{"type":"text","value":" (jiāowǎng) - \"associate with/have dealings with\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"交 embodies the Chinese cultural value of building relationships and maintaining social connections.\nThe concept of \"交情\" (jiāoqíng) - \"friendship/personal relationship\" - is fundamental to Chinese\nsociety, where many activities depend on established connections. In business and\npolitics, 交 represents the art of building networks and maintaining mutual benefit. The character\nreflects the Confucian emphasis on proper relationships between people, suggesting that meaningful\nexchange requires crossing boundaries to meet others halfway. This principle extends to\ninternational relations, where 外交 (diplomacy) literally means \"outside crossing\" - reaching across\nboundaries to build understanding."}],"type":"paragraph"}
