{
  "children":[
    {"children":[{"type":"text","value":"Dad; father; one's male parent; a familiar term for father."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Word Breakdown"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"爸爸 is a doubled form of 爸, creating an affectionate, informal way to address one's father."}],"type":"paragraph"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Component"}],"type":"tableCell"},{"children":[{"type":"text","value":"Meaning"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"爸"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Father (informal); dad"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"爸"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Repeated for affection and familiarity"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"The doubling pattern makes it more intimate and childlike, similar to \"daddy\" in English."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"爸爸 is the "},{"children":[{"type":"text","value":"most common informal way to address or refer to one's father"}],"type":"strong"},{"type":"text","value":":"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Direct address"}],"type":"strong"},{"type":"text","value":": \"爸爸，我回来了\" - \"Dad, I'm home\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Reference"}],"type":"strong"},{"type":"text","value":": \"我爸爸是医生\" - \"My dad is a doctor\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Child speech"}],"type":"strong"},{"type":"text","value":": Often a child's first word for father"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Family context"}],"type":"strong"},{"type":"text","value":": Used in casual, loving family situations"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"爸爸妈妈"}],"type":"strong"},{"type":"text","value":" (bà ba mā ma) - \"mom and dad; parents\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"爸爸的工作"}],"type":"strong"},{"type":"text","value":" (bà ba de gōng zuò) - \"dad's work\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"叫爸爸"}],"type":"strong"},{"type":"text","value":" (jiào bà ba) - \"call dad\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"我爸爸说"}],"type":"strong"},{"type":"text","value":" (wǒ bà ba shuō) - \"my dad says\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"爸爸 reflects the warm, close family relationships valued in Chinese culture. Unlike the more\nformal 父亲 (fù qīn), 爸爸 emphasizes emotional closeness and is used throughout life, not just in\nchildhood. It represents the affectionate side of father-child relationships in Chinese families."}],"type":"paragraph"}
