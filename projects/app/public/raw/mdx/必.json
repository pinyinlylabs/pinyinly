  "children":[
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"必 represents "},{"children":[{"type":"text","value":"absolute necessity or inevitability"}],"type":"strong"},{"type":"text","value":". It's used to express:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Obligation"}],"type":"strong"},{"type":"text","value":": 必须 (bì xū) - \"must; have to\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Certainty"}],"type":"strong"},{"type":"text","value":": 必然 (bì rán) - \"inevitable; bound to happen\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Requirement"}],"type":"strong"},{"type":"text","value":": 必要 (bì yào) - \"necessary; required\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Inevitability"}],"type":"strong"},{"type":"text","value":": 必定 (bì dìng) - \"certainly; definitely\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"必须去"}],"type":"strong"},{"type":"text","value":" (bì xū qù) - \"must go\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"必然结果"}],"type":"strong"},{"type":"text","value":" (bì rán jié guó) - \"inevitable result\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"必要条件"}],"type":"strong"},{"type":"text","value":" (bì yào tiáo jiàn) - \"necessary conditions\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"必定成功"}],"type":"strong"},{"type":"text","value":" (bì dìng chéng gōng) - \"definitely will succeed\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"必 reflects the Chinese philosophical concept of inevitability and natural order. In Chinese\nthought, certain things follow natural laws and cannot be avoided - they \"must\" happen. This\ncharacter appears frequently in formal writing and philosophical texts to express certainty and\nlogical necessity."}],"type":"paragraph"}
