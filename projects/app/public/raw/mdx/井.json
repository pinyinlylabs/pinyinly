    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"井 represents "},{"children":[{"type":"text","value":"structured access to resources and orderly arrangements"}],"type":"strong"},{"type":"text","value":". It's used for:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Water wells"}],"type":"strong"},{"type":"text","value":": 水井 (shuǐjǐng) - \"water well\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Oil wells"}],"type":"strong"},{"type":"text","value":": 油井 (yóujǐng) - \"oil well\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Orderliness"}],"type":"strong"},{"type":"text","value":": 井然有序 (jǐngrán yǒuxù) - \"in good order\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Mining"}],"type":"strong"},{"type":"text","value":": 矿井 (kuàngjǐng) - \"mine shaft\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"深井"}],"type":"strong"},{"type":"text","value":" (shēnjǐng) - \"deep well\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"天井"}],"type":"strong"},{"type":"text","value":" (tiānjǐng) - \"courtyard/skylight\" (heaven + well)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"井水"}],"type":"strong"},{"type":"text","value":" (jǐngshuǐ) - \"well water\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"坐井观天"}],"type":"strong"},{"type":"text","value":" (zuò jǐng guān tiān) - \"view the sky from the bottom of a well\" (limited perspective)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"井井有条"}],"type":"strong"},{"type":"text","value":" (jǐngjǐng yǒutiáo) - \"everything in perfect order\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"井 holds deep significance in Chinese civilization as the center of community life. Traditional\nChinese villages were organized around wells, which served as gathering places for social\ninteraction and community decision-making. The \"井田制\" (jǐngtián zhì) - \"well-field system\" - was\nan ancient land distribution method where eight families farmed plots around a central well. Wells\nrepresent life-sustaining resources and the importance of community cooperation. The phrase\n\"井水不犯河水\" (jǐngshuǐ bù fàn héshuǐ) - \"well water doesn't interfere with river water\" - means\nkeeping separate spheres of influence and avoiding conflicts."}],"type":"paragraph"}
  ],
