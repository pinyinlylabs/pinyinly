    {"children":[{"type":"text","value":"The west part of a certain area; west side; western area."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"西边 represents "},{"children":[{"type":"text","value":"the western side, area, or direction relative to a reference point"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Location description"}],"type":"strong"},{"type":"text","value":": 在西边 (zài xībiān) - \"on the west side\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Directional reference"}],"type":"strong"},{"type":"text","value":": 房子西边 (fángzi xībiān) - \"west side of the house\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Geographic areas"}],"type":"strong"},{"type":"text","value":": 城市西边 (chéngshì xībiān) - \"western part of the city\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Relative position"}],"type":"strong"},{"type":"text","value":": 往西边走 (wǎng xībiān zǒu) - \"go toward the west side\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
