{
  "children":[
    {"children":[{"type":"text","value":"The vehicles, people, etc., moving along a route."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Word Breakdown"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"交通 combines concepts of interaction and flow to represent movement and connectivity."}],"type":"paragraph"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Component"}],"type":"tableCell"},{"children":[{"type":"text","value":"Meaning"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"交"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Hand over, intersect - person (人) with crossed legs (乂)"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"通"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Pass through, connect - movement (辶) + penetrate (用)"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"The combination suggests the intersection and flow of movement, creating systems of connection and\ntransportation."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"交通 represents "},{"children":[{"type":"text","value":"systems and infrastructure that enable movement of people, vehicles, and goods"}],"type":"strong"},{"type":"text","value":".\nIt's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Traffic flow"}],"type":"strong"},{"type":"text","value":": 交通堵塞 (jiāotōng dǔsè) - \"traffic jam\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Transportation"}],"type":"strong"},{"type":"text","value":": 公共交通 (gōnggòng jiāotōng) - \"public transportation\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Infrastructure"}],"type":"strong"},{"type":"text","value":": 交通工具 (jiāotōng gōngjù) - \"transportation means\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Safety"}],"type":"strong"},{"type":"text","value":": 交通安全 (jiāotōng ānquán) - \"traffic safety\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"交通便利"}],"type":"strong"},{"type":"text","value":" (jiāotōng biànlì) - \"convenient transportation\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"交通规则"}],"type":"strong"},{"type":"text","value":" (jiāotōng guīzé) - \"traffic rules\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"交通事故"}],"type":"strong"},{"type":"text","value":" (jiāotōng shìgù) - \"traffic accident\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"交通灯"}],"type":"strong"},{"type":"text","value":" (jiāotōng dēng) - \"traffic light\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"轨道交通"}],"type":"strong"},{"type":"text","value":" (guǐdào jiāotōng) - \"rail transportation\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"交通 reflects the importance of connectivity and flow in Chinese urban planning and social\norganization. In modern China, efficient 交通 is seen as essential for economic development and\nquality of life. The concept extends beyond physical movement to include communication and\ninformation flow, reflecting traditional Chinese values of harmony and smooth operation. The phrase\n\"四通八达\" (sì tōng bā dá) - \"accessible from all directions\" - emphasizes the cultural importance\nof connectivity and the free flow of people, goods, and ideas in building prosperous communities."}],"type":"paragraph"}
