{
  "children":[
    {"children":[{"type":"text","value":"The side or part facing north; the north side; northern area."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"北边 represents "},{"children":[{"type":"text","value":"the northern side, area, or direction relative to a reference point"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Location description"}],"type":"strong"},{"type":"text","value":": 在北边 (zài běibiān) - \"on the north side\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Directional reference"}],"type":"strong"},{"type":"text","value":": 房子的北边 (fángzi de běibiān) - \"the north side of the house\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Geographic areas"}],"type":"strong"},{"type":"text","value":": 城市北边 (chéngshì běibiān) - \"the northern part of the city\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Relative position"}],"type":"strong"},{"type":"text","value":": 往北边走 (wǎng běibiān zǒu) - \"go toward the north side\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
