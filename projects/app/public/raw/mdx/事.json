    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"事 represents "},{"children":[{"type":"text","value":"affairs, matters, or events that require attention or action"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"General affairs"}],"type":"strong"},{"type":"text","value":": 事情 (shìqíng) - \"matter; affair\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Work matters"}],"type":"strong"},{"type":"text","value":": 工作的事 (gōngzuò de shì) - \"work matters\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Personal matters"}],"type":"strong"},{"type":"text","value":": 个人的事 (gèrén de shì) - \"personal affairs\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Important events"}],"type":"strong"},{"type":"text","value":": 大事 (dàshì) - \"major event\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"没事"}],"type":"strong"},{"type":"text","value":" (méi shì) - \"nothing's wrong; it's okay\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"有事"}],"type":"strong"},{"type":"text","value":" (yǒu shì) - \"have something to do; be busy\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"事实"}],"type":"strong"},{"type":"text","value":" (shìshí) - \"fact; reality\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"故事"}],"type":"strong"},{"type":"text","value":" (gùshì) - \"story\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"办事"}],"type":"strong"},{"type":"text","value":" (bànshì) - \"handle affairs; do business\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"事 reflects the Chinese emphasis on practical affairs and social responsibility. In Chinese\nphilosophy, managing 事 (affairs) properly is seen as essential for harmony in family, community,\nand society. The concept connects to Confucian ideals of duty and proper conduct in handling\nresponsibilities. The phrase \"事在人为\" (shì zài rén wéi) - \"affairs depend on human effort\" -\nemphasizes that outcomes depend on how people handle situations, reflecting the Chinese belief in\nhuman agency and responsibility."}],"type":"paragraph"}
