    {"children":[{"type":"text","value":"从前 represents "},{"children":[{"type":"text","value":"reference to past time periods"}],"type":"strong"},{"type":"text","value":":"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Stories"}],"type":"strong"},{"type":"text","value":": \"从前有一个...\" - \"once upon a time there was...\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Personal history"}],"type":"strong"},{"type":"text","value":": \"从前我住在...\" - \"I used to live in...\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Comparison"}],"type":"strong"},{"type":"text","value":": \"从前和现在\" - \"then and now\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Nostalgia"}],"type":"strong"},{"type":"text","value":": \"想起从前\" - \"remember the past\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"从前的日子"}],"type":"strong"},{"type":"text","value":" (cóng qián de rì zi) - \"the old days\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"从前有"}],"type":"strong"},{"type":"text","value":" (cóng qián yǒu) - \"once there was\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不像从前"}],"type":"strong"},{"type":"text","value":" (bù xiàng cóng qián) - \"not like before\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"从前到现在"}],"type":"strong"},{"type":"text","value":" (cóng qián dào xiàn zài) - \"from past to present\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"从前 carries nostalgic and storytelling associations in Chinese culture. It's commonly used to begin\ntraditional stories and personal reminiscences. The phrase evokes a sense of connection to history\nand the passing of time, reflecting Chinese cultural values of remembering the past and learning\nfrom experience."}],"type":"paragraph"}
