    {"children":[{"type":"text","value":"从前 combines following/from and front/ahead to reference earlier time."}],"type":"paragraph"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Component"}],"type":"tableCell"},{"children":[{"type":"text","value":"Meaning"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"从"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"From; follow; since; beginning with"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"前"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Front; ahead; before; earlier; prior"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"Together they create: \"from the front time\" or \"since the earlier period.\""}],"type":"paragraph"},
