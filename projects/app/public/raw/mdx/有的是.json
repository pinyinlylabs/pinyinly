{
  "children":[
    {"children":[{"type":"text","value":"Indicates having an abundance or plenty of something; there's plenty of; have a lot of; abundant."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"有的是 represents "},{"children":[{"type":"text","value":"abundance, plenty, and ample availability of something"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Reassurance"}],"type":"strong"},{"type":"text","value":": 时间有的是 (shíjiān yǒu de shì) - \"there's plenty of time\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Abundance"}],"type":"strong"},{"type":"text","value":": 钱有的是 (qián yǒu de shì) - \"there's plenty of money\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Availability"}],"type":"strong"},{"type":"text","value":": 机会有的是 (jīhuì yǒu de shì) - \"there are plenty of opportunities\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Comfort"}],"type":"strong"},{"type":"text","value":": 不用担心，有的是 (bùyòng dānxīn, yǒu de shì) - \"don't worry, there's plenty\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"时间有的是"}],"type":"strong"},{"type":"text","value":" (shíjiān yǒu de shì) - \"there's plenty of time\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"机会有的是"}],"type":"strong"},{"type":"text","value":" (jīhuì yǒu de shì) - \"there are plenty of opportunities\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"钱有的是"}],"type":"strong"},{"type":"text","value":" (qián yǒu de shì) - \"there's plenty of money\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"人有的是"}],"type":"strong"},{"type":"text","value":" (rén yǒu de shì) - \"there are plenty of people\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"办法有的是"}],"type":"strong"},{"type":"text","value":" (bànfǎ yǒu de shì) - \"there are plenty of ways\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"有的是 reflects Chinese cultural attitudes toward abundance and resourcefulness. It's often used to\nreassure others and express confidence in having sufficient resources. The phrase embodies an\noptimistic outlook and practical approach to problem-solving, suggesting that with enough of\nsomething (time, money, people, methods), challenges can be overcome."}],"type":"paragraph"}
