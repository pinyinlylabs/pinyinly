    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"As radical"}],"type":"strong"},{"type":"text","value":": In characters related to frogs and similar creatures"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Zoological context"}],"type":"strong"},{"type":"text","value":": 青蛙 (qīngwā) uses related concepts - \"green frog\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Traditional texts"}],"type":"strong"},{"type":"text","value":": In classical Chinese literature referring to amphibians"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Character composition"}],"type":"strong"},{"type":"text","value":": As a component in more complex characters"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
