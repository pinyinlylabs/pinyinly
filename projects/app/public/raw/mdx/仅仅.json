    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"仅仅一天"}],"type":"strong"},{"type":"text","value":" (jǐn jǐn yī tiān) - \"just one day\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"仅仅因为"}],"type":"strong"},{"type":"text","value":" (jǐn jǐn yīn wéi) - \"merely because\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"仅仅够用"}],"type":"strong"},{"type":"text","value":" (jǐn jǐn gòu yòng) - \"just barely enough\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不仅仅是"}],"type":"strong"},{"type":"text","value":" (bù jǐn jǐn shì) - \"not merely; not just\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"仅仅 reflects Chinese linguistic tendency to use repetition for emphasis. In Chinese communication,\nemphasizing limitation can show modesty or express surprise at how small something is. The double\nrepetition makes the speaker's point unmistakably clear about the minimal nature of what's being\ndescribed."}],"type":"paragraph"}
