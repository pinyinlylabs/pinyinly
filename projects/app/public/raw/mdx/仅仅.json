    {"children":[{"type":"text","value":"仅仅 represents "},{"children":[{"type":"text","value":"strong emphasis on limitation or minimal amount"}],"type":"strong"},{"type":"text","value":":"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Small quantity"}],"type":"strong"},{"type":"text","value":": \"仅仅十块钱\" - \"only ten yuan\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Limited scope"}],"type":"strong"},{"type":"text","value":": \"仅仅是开始\" - \"merely the beginning\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Minimal effort"}],"type":"strong"},{"type":"text","value":": \"仅仅试了一下\" - \"just tried once\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Restriction"}],"type":"strong"},{"type":"text","value":": \"仅仅三个人\" - \"only three people\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
