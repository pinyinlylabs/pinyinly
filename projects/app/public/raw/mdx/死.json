    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"死 represents "},{"children":[{"type":"text","value":"death, dying, and the state of being dead"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Literal death"}],"type":"strong"},{"type":"text","value":": 死了 (sǐ le) - \"died; is dead\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"State of being"}],"type":"strong"},{"type":"text","value":": 死的 (sǐ de) - \"dead (adjective)\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Extreme emphasis"}],"type":"strong"},{"type":"text","value":": 累死了 (lèi sǐ le) - \"extremely tired\" (literally \"tired to death\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Fixed expressions"}],"type":"strong"},{"type":"text","value":": 死心 (sǐxīn) - \"give up hope\" (literally \"dead heart\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
