    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Announcement"}],"type":"strong"},{"type":"text","value":": 现在下课 (xiànzài xiàkè) - \"class is over now\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Time reference"}],"type":"strong"},{"type":"text","value":": 下课后 (xiàkè hòu) - \"after class\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Daily schedule"}],"type":"strong"},{"type":"text","value":": 什么时候下课 (shénme shíhou xiàkè) - \"when does class end?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"School context"}],"type":"strong"},{"type":"text","value":": 下课铃声 (xiàkè língshēng) - \"end-of-class bell\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
