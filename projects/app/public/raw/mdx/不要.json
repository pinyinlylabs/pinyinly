    {"children":[{"type":"text","value":"Used to express a prohibition or a request not to do something; don't."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"不要 expresses "},{"children":[{"type":"text","value":"prohibition, strong advice against, or commands not to do something"}],"type":"strong"},{"type":"text","value":". It's used\nto:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Give commands"}],"type":"strong"},{"type":"text","value":": 不要走 (bù yào zǒu) - \"don't go\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Express prohibition"}],"type":"strong"},{"type":"text","value":": 不要吸烟 (bù yào xīyān) - \"no smoking\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Give advice"}],"type":"strong"},{"type":"text","value":": 不要担心 (bù yào dānxīn) - \"don't worry\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Make requests"}],"type":"strong"},{"type":"text","value":": 不要说话 (bù yào shuōhuà) - \"don't talk\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不要紧"}],"type":"strong"},{"type":"text","value":" (bù yàojǐn) - \"it doesn't matter; no problem\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不要脸"}],"type":"strong"},{"type":"text","value":" (bù yào liǎn) - \"shameless\" (literally \"don't want face\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不要急"}],"type":"strong"},{"type":"text","value":" (bù yào jí) - \"don't rush\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不要哭"}],"type":"strong"},{"type":"text","value":" (bù yào kū) - \"don't cry\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不要忘记"}],"type":"strong"},{"type":"text","value":" (bù yào wàngjì) - \"don't forget\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Comparison with 不用"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不要"}],"type":"strong"},{"type":"text","value":": Direct prohibition or command (\"Don't do it!\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不用"}],"type":"strong"},{"type":"text","value":": Gentle permission (\"You don't need to\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
