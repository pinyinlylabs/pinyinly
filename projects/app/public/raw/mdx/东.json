    {"children":[{"type":"text","value":"东 represents "},{"children":[{"type":"text","value":"the cardinal direction east, eastern things, or the Orient"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"As a direction"}],"type":"strong"},{"type":"text","value":": 往东走 (wǎng dōng zǒu) - \"go east\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Geographic regions"}],"type":"strong"},{"type":"text","value":": 东方 (dōngfāng) - \"the East/Orient\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"In compounds"}],"type":"strong"},{"type":"text","value":": 东西 (dōngxī) - \"things, stuff\" (literally \"east-west\")"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Locations"}],"type":"strong"},{"type":"text","value":": 东边 (dōngbiān) - \"eastern side\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
