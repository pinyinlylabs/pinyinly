{
  "children":[
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"买 represents "},{"children":[{"type":"text","value":"the act of acquiring goods or services through payment"}],"type":"strong"},{"type":"text","value":". It's used:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"General purchasing"}],"type":"strong"},{"type":"text","value":": 买东西 (mǎi dōngxi) - \"buy things\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Food shopping"}],"type":"strong"},{"type":"text","value":": 买菜 (mǎi cài) - \"buy groceries\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Major purchases"}],"type":"strong"},{"type":"text","value":": 买房子 (mǎi fángzi) - \"buy a house\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Services"}],"type":"strong"},{"type":"text","value":": 买票 (mǎi piào) - \"buy tickets\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"买书"}],"type":"strong"},{"type":"text","value":" (mǎi shū) - \"buy books\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"买衣服"}],"type":"strong"},{"type":"text","value":" (mǎi yīfu) - \"buy clothes\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"买单"}],"type":"strong"},{"type":"text","value":" (mǎi dān) - \"pay the bill\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"购买"}],"type":"strong"},{"type":"text","value":" (gòumǎi) - \"purchase\" (formal)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"买不起"}],"type":"strong"},{"type":"text","value":" (mǎi bù qǐ) - \"can't afford to buy\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"买 reflects the fundamental role of commerce in Chinese society. The concept connects to traditional\nmarket culture where bargaining and relationship-building are important aspects of purchasing. The\nphrase \"买卖\" (mǎimài) combines buying and selling, emphasizing that commerce is about mutual\nexchange and relationship. In modern China, 买 has expanded to include online shopping culture,\nreflecting the rapid digitization of commerce and the importance of consumption in economic\ndevelopment."}],"type":"paragraph"}
