{
  "children":[
    {"children":[{"type":"text","value":"Excuse me; may I ask; pardon me; a polite expression for asking questions."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Word Breakdown"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"请问 combines politeness and inquiry to create respectful questioning."}],"type":"paragraph"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Component"}],"type":"tableCell"},{"children":[{"type":"text","value":"Meaning"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"请"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Please; request; invite; ask politely"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"问"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Ask; question; inquire; interrogate"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"Together they create: \"please ask\" or \"politely request to inquire.\""}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Core Meaning & Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"请问 represents "},{"children":[{"type":"text","value":"polite introduction to questions and requests"}],"type":"strong"},{"type":"text","value":":"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Directions"}],"type":"strong"},{"type":"text","value":": \"请问，车站在哪里？\" - \"Excuse me, where is the station?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Information"}],"type":"strong"},{"type":"text","value":": \"请问您的名字？\" - \"May I ask your name?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Assistance"}],"type":"strong"},{"type":"text","value":": \"请问可以帮忙吗？\" - \"Excuse me, could you help?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Clarification"}],"type":"strong"},{"type":"text","value":": \"请问什么意思？\" - \"May I ask what this means?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":true,"spread":false,"start":1,"type":"list"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"请问路怎么走"}],"type":"strong"},{"type":"text","value":" (qǐng wèn lù zěn me zǒu) - \"excuse me, how do I get there?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"请问几点了"}],"type":"strong"},{"type":"text","value":" (qǐng wèn jǐ diǎn le) - \"excuse me, what time is it?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"请问您贵姓"}],"type":"strong"},{"type":"text","value":" (qǐng wèn nín guì xìng) - \"may I ask your surname?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"请问在吗"}],"type":"strong"},{"type":"text","value":" (qǐng wèn zài ma) - \"excuse me, are you there?\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"请问 embodies Chinese cultural values of politeness and respect in social interaction.\nUsing 请问 shows consideration for others and proper social etiquette. It reflects the cultural\nprinciple that approaching strangers or making requests should be done with appropriate courtesy and\nrespect for the other person's time and attention."}],"type":"paragraph"}
