{
  "children":[
    {"children":[{"type":"text","value":"A conjunction meaning \"not only\" or \"not just,\" used to introduce additional information that\nreinforces or complements what was previously stated."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Word Breakdown"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"不光 combines negation with limitation to expand scope:"}],"type":"paragraph"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Component"}],"type":"tableCell"},{"children":[{"type":"text","value":"Meaning"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"不"}],"type":"strong"},{"type":"text","value":" (bù)"}],"type":"tableCell"},{"children":[{"type":"text","value":"Not, negation"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"光"}],"type":"strong"},{"type":"text","value":" (guāng)"}],"type":"tableCell"},{"children":[{"type":"text","value":"Only, just, merely (in this context)"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"Understanding"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"Think of 不光 as "},{"children":[{"type":"text","value":"\"there's more light to shed on this\""}],"type":"strong"},{"type":"text","value":":"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"光 here means \"only\" (like a spotlight focusing on one thing)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"不光 opens up the view to see more than just that one thing"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Similar to 不但 but often more colloquial and conversational"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Creates anticipation for additional supporting information"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Often used with 还 (hái), 也 (yě), or 而且 (érqiě)"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Usage Patterns"}],"depth":2,"type":"heading"},
    {"children":[{"children":[{"type":"text","value":"不光...还... (bùguāng...hái...)"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"type":"text","value":"Most common pattern - \"not only...but also...\""}],"type":"paragraph"},
    {"children":[{"children":[{"type":"text","value":"不光...也... (bùguāng...yě...)"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"type":"text","value":"\"Not only...but also...\" (casual conversation)"}],"type":"paragraph"},
    {"children":[{"children":[{"type":"text","value":"不光如此... (bùguāng rúcǐ...)"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"type":"text","value":"\"Not only that...\" (introducing further evidence)"}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Examples"}],"depth":2,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"他不光会唱歌，还会跳舞。"}],"type":"strong"}],"type":"paragraph"},{"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"\"He can not only sing, but also dance.\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"这家餐厅不光菜好吃，服务也很好。"}],"type":"strong"}],"type":"paragraph"},{"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"\"This restaurant not only has delicious food, but the service is also excellent.\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"不光是学生，老师也很喜欢这个活动。"}],"type":"strong"}],"type":"paragraph"},{"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"\"Not only students, but teachers also really like this activity.\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"她不光汉语说得好，英语也很流利。"}],"type":"strong"}],"type":"paragraph"},{"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"\"She not only speaks Chinese well, but her English is also very fluent.\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":true,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Comparison with Similar Words"}],"depth":2,"type":"heading"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Word"}],"type":"tableCell"},{"children":[{"type":"text","value":"Usage"}],"type":"tableCell"},{"children":[{"type":"text","value":"Tone"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"type":"text","value":"不但"}],"type":"tableCell"},{"children":[{"type":"text","value":"More formal, written language"}],"type":"tableCell"},{"children":[{"type":"text","value":"Formal"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"type":"text","value":"不光"}],"type":"tableCell"},{"children":[{"type":"text","value":"More casual, spoken language"}],"type":"tableCell"},{"children":[{"type":"text","value":"Colloquial"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"type":"text","value":"不仅"}],"type":"tableCell"},{"children":[{"type":"text","value":"Very formal, academic/literary"}],"type":"tableCell"},{"children":[{"type":"text","value":"Formal"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"Cultural Usage"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"不光 appears frequently in:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Daily conversation"}],"type":"strong"},{"type":"text","value":" - casual praise or description"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Product descriptions"}],"type":"strong"},{"type":"text","value":" - highlighting multiple benefits"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Informal presentations"}],"type":"strong"},{"type":"text","value":" - building persuasive arguments"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Social media"}],"type":"strong"},{"type":"text","value":" - describing experiences or people"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"不光 typically appears at the beginning of a sentence or clause, setting up the expectation for\nadditional information. The second part often begins with 还, 也, 而且, or similar connectors."}],"type":"paragraph"},
    {"children":[{"children":[{"type":"text","value":"Pattern"}],"type":"strong"},{"type":"text","value":": 不光 + [first item] + [connector] + [additional item(s)]"}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Using 不光 makes your Chinese sound "},{"children":[{"type":"text","value":"natural and conversational"}],"type":"strong"},{"type":"text","value":" while building compelling,\nmulti-layered descriptions."}],"type":"paragraph"}
