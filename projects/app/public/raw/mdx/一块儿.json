    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"The 儿 (retroflex) ending is characteristic of Beijing speech"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"In Southern dialects, people might say "},{"children":[{"type":"text","value":"一起"}],"type":"strong"},{"type":"text","value":" (yīqǐ) instead"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Both mean \"together\" but 一块儿 sounds more casual and friendly"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Using 一块儿 gives your Chinese a Beijing flavor"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
