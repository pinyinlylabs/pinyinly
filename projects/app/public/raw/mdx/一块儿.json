    {"children":[{"type":"text","value":"一块儿 reflects important Chinese social values:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Collective harmony"}],"type":"strong"},{"type":"text","value":": Doing things together is preferred over individual action"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Group solidarity"}],"type":"strong"},{"type":"text","value":": The \"one piece\" metaphor emphasizes unity"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Warm relationships"}],"type":"strong"},{"type":"text","value":": The casual tone suggests close, comfortable relationships"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"Shared experiences"}],"type":"strong"},{"type":"text","value":": Chinese culture values shared activities and mutual support"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
