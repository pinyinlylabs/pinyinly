    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"没有"}],"type":"strong"},{"type":"text","value":" (méi yǒu) - \"don't have; there isn't; no\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"没关系"}],"type":"strong"},{"type":"text","value":" (méi guān xi) - \"it doesn't matter; no problem\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"没事"}],"type":"strong"},{"type":"text","value":" (méi shì) - \"it's okay; no problem; nothing's wrong\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"我没去"}],"type":"strong"},{"type":"text","value":" (wǒ méi qù) - \"I didn't go\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Notes"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"没 is the primary negation for past actions and possession:"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"Used specifically to negate 有 (yǒu) \"to have\": 没有 (méi yǒu)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Used for past actions that didn't happen: 没 + verb"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Different from 不 (bù) which negates present/future states"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Essential for expressing what someone doesn't have or didn't do"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Critical for understanding Chinese tense and aspect"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"没 represents the concept of absence and non-occurrence, essential for accurate communication about\nwhat exists, what doesn't exist, and what didn't happen."}],"type":"paragraph"}
  ],
