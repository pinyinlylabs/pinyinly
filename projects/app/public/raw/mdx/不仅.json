{
  "children":[
    {"children":[{"type":"text","value":"Not only; not just; not merely; used to introduce additional information that goes beyond what was\npreviously mentioned."}],"type":"paragraph"},
    {"children":[{"type":"text","value":"Word Breakdown"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"不仅 combines negation with limitation to create expansion and addition."}],"type":"paragraph"},
    {"align":[],"children":[{"children":[{"children":[{"type":"text","value":"Component"}],"type":"tableCell"},{"children":[{"type":"text","value":"Meaning"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"不"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Not; no - negation marker"}],"type":"tableCell"}],"type":"tableRow"},{"children":[{"children":[{"children":[{"type":"text","value":"仅"}],"type":"strong"}],"type":"tableCell"},{"children":[{"type":"text","value":"Only; merely; just - indicating limitation"}],"type":"tableCell"}],"type":"tableRow"}],"type":"table"},
    {"children":[{"type":"text","value":"Understanding"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"Think of 不仅 as "},{"children":[{"type":"text","value":"\"not stopping at just this\""}],"type":"strong"},{"type":"text","value":":"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"It signals that what you just mentioned is only the beginning"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Like saying \"that's not all\" or \"there's more\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"It sets up the listener to expect additional, often more impressive information"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Often paired with words like 而且 (moreover), 还 (also), or 也 (also)"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Creates a sense of escalating importance or impressiveness"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Patterns"}],"depth":2,"type":"heading"},
    {"children":[{"children":[{"type":"text","value":"Classic Pattern: 不仅...而且..."}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"children":[{"type":"text","value":"Structure"}],"type":"strong"},{"type":"text","value":": 不仅 + Statement A + 而且 + Statement B"}],"type":"paragraph"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"他不仅聪明，而且勤奋"}],"type":"strong"},{"type":"text","value":" (tā bùjǐn cōngmíng, érqiě qínfèn) - \"He's not only smart, but also\ndiligent\""}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"这本书不仅有趣，而且有用"}],"type":"strong"},{"type":"text","value":" (zhè běn shū bùjǐn yǒuqù, érqiě yǒuyòng) - \"This book is not only\ninteresting, but also useful\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"children":[{"type":"text","value":"Pattern with 还 (also)"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"他不仅会说中文，还会说日文"}],"type":"strong"},{"type":"text","value":" (tā bùjǐn huì shuō zhōngwén, hái huì shuō rìwén) - \"He not only\nspeaks Chinese, but also speaks Japanese\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"children":[{"type":"text","value":"Pattern with 也 (also)"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"children":[{"type":"text","value":"我不仅喜欢音乐，也喜欢电影"}],"type":"strong"},{"type":"text","value":" (wǒ bùjǐn xǐhuān yīnyuè, yě xǐhuān diànyǐng) - \"I not only like\nmusic, I also like movies\""}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
