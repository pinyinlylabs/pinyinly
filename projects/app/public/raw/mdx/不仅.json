    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"At the beginning of the sentence: 不仅 + first clause"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"After the subject: Subject + 不仅 + predicate"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
