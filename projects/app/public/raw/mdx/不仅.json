    {"children":[{"type":"text","value":"Cultural Context"}],"depth":2,"type":"heading"},
    {"children":[{"type":"text","value":"不仅 reflects Chinese communication patterns:"}],"type":"paragraph"},
    {"children":[{"children":[{"type":"text","value":"Building Up Information"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"Chinese speakers often present information in escalating importance"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Start with something good, then reveal something even better"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Creates anticipation and maintains listener interest"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"children":[{"type":"text","value":"Modesty and Surprise"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"Often used to modestly introduce impressive achievements"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"The structure allows for humble beginning followed by impressive addition"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Shows cultural preference for understated revelation of accomplishments"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"children":[{"type":"text","value":"Logical Progression"}],"type":"strong"}],"depth":3,"type":"heading"},
    {"children":[{"checked":null,"children":[{"children":[{"type":"text","value":"Reflects Chinese rhetorical style of building logical arguments"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Each piece of information strengthens the overall point"}],"type":"paragraph"}],"spread":false,"type":"listItem"},{"checked":null,"children":[{"children":[{"type":"text","value":"Common in academic and professional discourse"}],"type":"paragraph"}],"spread":false,"type":"listItem"}],"ordered":false,"spread":false,"start":null,"type":"list"},
    {"children":[{"type":"text","value":"Grammar Tips"}],"depth":2,"type":"heading"},
